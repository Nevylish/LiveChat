{
    "compilerOptions": {
        "strict": true,
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "target": "ES2020",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "types": ["node"],
        "outDir": "dist/",
        "rootDir": "src/"
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"],
    "references": [{ "path": "../types" }]
}
