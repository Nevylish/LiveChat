{
    "name": "livechat",
    "description": "Un overlay OBS qui permet à vos amis d'afficher des médias sur votre stream",
    "version": "1.6.5",
    "license": "GPL-3.0-only",
    "private": true,
    "homepage": "https://livechat.nevylish.fr/",
    "author": {
        "name": "Nevylish",
        "email": "bonjour@nevylish.fr",
        "url": "https://nevylish.fr/"
    },
    "scripts": {
        "clean:modules": "node -e \"const fs=require('fs'); ['node_modules', 'packages/server/node_modules', 'packages/web/node_modules', 'packages/overlay/node_modules'].forEach(p => fs.rmSync(p, {recursive:true,force:true}))\"",
        "build": "pnpm --filter @livechat/server build && pnpm --filter @livechat/web build",
        "build:server": "pnpm --filter @livechat/server build",
        "build:web": "pnpm --filter @livechat/web build",
        "dev:server": "pnpm --filter @livechat/server dev",
        "dev:web": "pnpm --filter @livechat/web dev",
        "start": "pnpm --filter @livechat/server start",
        "clean": "pnpm --filter @livechat/server exec node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && pnpm --filter @livechat/web exec node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "prettier": "^3.8.1"
    },
    "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215"
}
